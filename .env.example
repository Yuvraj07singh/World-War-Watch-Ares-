# ═══════════════════════════════════════════════
#  World War Watch — Environment Configuration
# ═══════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────
# Google Gemini API Key (FREE — get at https://aistudio.google.com/app/apikey)
# Free tier: 15 requests/min, 1 million tokens/day — more than enough
GEMINI_API_KEY=your-gemini-api-key-here

# ── OPTIONAL ────────────────────────────────────
PORT=3000

# How often to auto-update news (in minutes). Default: 60
UPDATE_INTERVAL_MINUTES=60

# Optional admin key to protect manual update trigger
# ADMIN_KEY=your-secret-key-here

NODE_ENV=production
