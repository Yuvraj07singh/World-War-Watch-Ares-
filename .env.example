# ═══════════════════════════════════════════════
#  World War Watch — Environment Configuration
# ═══════════════════════════════════════════════

# ── AI PROVIDERS (4-Layer Failover) ────────────
# At minimum, set GEMINI_API_KEY. Add more for extra resilience.

# Layer 1: Google Gemini 2.5 Flash (PRIMARY)
# FREE — get at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Layer 2: Cerebras (Llama 3.3 70B — BLAZING FAST)
# FREE — get at https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Layer 3: OpenRouter (100+ models gateway)
# FREE — get at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Layer 4: Pollinations (NO KEY NEEDED — always available as last resort)

# Legacy: Groq (optional, kept for backward compatibility)
# GROQ_API_KEY=your-groq-api-key-here

# ── OPTIONAL ────────────────────────────────────
PORT=3000

# How often to auto-update news (in minutes). Default: 60
UPDATE_INTERVAL_MINUTES=60

# Optional admin key to protect manual update trigger
# ADMIN_KEY=your-secret-key-here

NODE_ENV=production
